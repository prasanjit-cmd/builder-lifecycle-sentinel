{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": false,
    "jsx": "react-jsx",
    "types": ["node", "react", "react-dom"],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "backend/**/*.ts",
    "db/**/*.ts",
    "dashboard/components/**/*.ts",
    "dashboard/components/**/*.tsx",
    "dashboard/hooks/**/*.ts",
    "dashboard/layout.tsx",
    "dashboard/main.tsx",
    "dashboard/pages/**/*.tsx"
  ],
  "exclude": ["node_modules", "dist", "dashboard/dist"]
}
