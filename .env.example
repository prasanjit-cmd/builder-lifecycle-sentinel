# Environment variables for this agent
# Copy to .env and fill in values

# Database
DATABASE_URL=postgresql://agent:agent@localhost:5432/agent

# Agent credentials
# Default workspace path to inspect when the operator does not specify one.
BUILDER_SENTINEL_DEFAULT_WORKSPACE=
# Expected agent name used for exact-agent checks.
BUILDER_SENTINEL_DEFAULT_AGENT_NAME=
# Maximum number of local log files to inspect per run.
BUILDER_SENTINEL_MAX_LOG_FILES=
# Maximum bytes read from any one log file.
BUILDER_SENTINEL_MAX_LOG_BYTES=
# Maximum bytes stored in one evidence excerpt.
BUILDER_SENTINEL_MAX_LOG_EXCERPT_BYTES=
# Timeout for read-only local CLI probes.
BUILDER_SENTINEL_COMMAND_TIMEOUT_MS=
# Timeout for bounded log inspection probes.
BUILDER_SENTINEL_LOG_TIMEOUT_MS=
# When true, ship/deploy readiness is never assumed without operator approval evidence.
BUILDER_SENTINEL_REQUIRE_EXPLICIT_SHIP_APPROVAL=
# Must remain false for this local-only Sentinel.
BUILDER_SENTINEL_ALLOW_EXTERNAL_CALLS=

# Server
PORT=8080
NODE_ENV=development
